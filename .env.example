AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

S3_BUCKET_NAME=your-uscis-docs-bucket
S3_PREFIX=docs/
S3_DOCUMENT_KEY=docs/policy-manual/uscis_policy_manual_full_2026.pdf

POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/uscis_rag

EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=1024
EMBEDDING_NORMALIZE=true
CHAT_MODEL_ID=us.anthropic.claude-sonnet-4-6


TEMPERATURE=0.0
MMR_LAMBDA=0.7
HIGH_CONFIDENCE_THRESHOLD=0.70
LOW_CONFIDENCE_THRESHOLD=0.50
LOG_LEVEL=INFO
